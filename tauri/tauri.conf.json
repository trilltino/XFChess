{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/v2.10.3/crates/tauri-config-schema/schema.json",
  "productName": "XFChess",
  "version": "0.1.0",
  "identifier": "com.xfchess.app",
  "build": {
    "frontendDist": "./wallet-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": "cd wallet-ui && npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "XFChess",
        "label": "main",
        "url": "index.html",
        "width": 400,
        "height": 660,
        "minWidth": 360,
        "minHeight": 600,
        "visible": false,
        "decorations": true,
        "center": true
      },
      {
        "title": "XFChess Wallet",
        "label": "wallet-popup",
        "url": "http://localhost:7454/wallet-popup/",
        "width": 420,
        "height": 500,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets/**/*",
      "../stockfish.exe"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["xfchess"]
      }
    }
  }
}
