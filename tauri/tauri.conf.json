{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/v2.10.3/crates/tauri-config-schema/schema.json",
  "productName": "XFChess",
  "version": "0.1.0",
  "identifier": "com.xfchess.app",
  "build": {
    "frontendDist": "./wallet-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": "cd wallet-ui && npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ws: http://localhost:8090 https://api.xfchess.com",
        "script-src": "'self' 'unsafe-inline'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: https:",
        "font-src": "'self' data:",
        "object-src": "'none'",
        "media-src": "'self'",
        "frame-src": "'none'"
      }
    },
    "windows": [
      {
        "title": "XFChess",
        "label": "main",
        "url": "index.html",
        "width": 400,
        "height": 660,
        "minWidth": 360,
        "minHeight": 600,
        "visible": false,
        "decorations": true,
        "center": true,
        "dragDropEnabled": false
              },
      {
        "title": "XFChess Wallet",
        "label": "wallet-popup",
        "url": "http://localhost:7455/wallet-popup/",
        "width": 420,
        "height": 500,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": false,
        "dragDropEnabled": false
      },
      {
        "title": "XFChess Tournament Admin",
        "label": "tournament-admin",
        "url": "http://localhost:7454/tournament-admin/",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets/**/*",
      "../stockfish.exe"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["xfchess"]
      }
    }
  }
}
