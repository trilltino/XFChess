{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XFChess Viz",
  "version": "0.1.0",
  "identifier": "com.xfchess.viz",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "XFChess Network Visualiser",
        "label": "main",
        "width": 1320,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
