# XFChess Backend Environment Variables

# Admin API Key - Required for admin tournament operations
# Set this to a secure random string (e.g., 32+ characters)
# The VPS admin console and admin endpoints require this key
ADMIN_API_KEY=your-secure-api-key-here-change-me

# Signing Service URL - Where the backend is hosted
# For local development with ngrok, use your ngrok URL
SIGNING_SERVICE_URL=https://your-ngrok-url.ngrok-free.app

# JWT Secret - For authentication tokens
JWT_SECRET=your-jwt-secret-here

# Database URLs
DATABASE_URL=sqlite://sessions.db?mode=rwc
VAULT_DATABASE_URL=sqlite://vault.db?mode=rwc

# Solana RPC URL (for on-chain operations)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Program ID (xfchess-game program on Solana)
PROGRAM_ID=FVPp29xDtMrh3CrTJNnxDcbGRnMMKuUv2ntqkBRc1uDX

# SendGrid API Key - For sending welcome PDF emails to new signups
# Get your API key at: https://app.sendgrid.com/settings/api_keys
# Create a key with "Mail Send" permissions
# Without this, signup PDF emails won't be sent
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
