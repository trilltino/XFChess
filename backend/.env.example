# XFChess Backend Environment Variables

# Admin API Key — transport gate for the ENTIRE /admin/* router (checked as the
# X-API-Key header by require_api_key, constant-time). Every admin/VPS/tournament
# operation requires it. Set to a secure random string (32+ chars).
# NOTE: /admin/* is never exposed publicly (nginx returns 444) — operators reach
# it via an SSH tunnel to 127.0.0.1:8090. See docs/plans/admin-panel-and-production-hardening.md.
ADMIN_API_KEY=your-secure-api-key-here-change-me

# Signing Service URL - Where the backend is hosted
# For local development with ngrok, use your ngrok URL
SIGNING_SERVICE_URL=https://your-ngrok-url.ngrok-free.app

# JWT Secret - For authentication tokens
JWT_SECRET=your-jwt-secret-here

# JWT token lifetime in seconds (optional; default 604800 = 7 days)
# JWT_TTL_SECS=604800

# Relay shared secret — application-layer auth for the session-key signing
# endpoints (/move/record, /session/*, /game/finalize, ...).
# Generate with:  openssl rand -hex 32
# MUST be set to the SAME value in the game client's environment (it sends it as
# the X-Relay-Secret header). When unset the backend fails OPEN (relies on the
# network boundary) and logs a one-time warning.
# NOTE: the desktop client ships with this value, so treat it as defense-in-depth
# (blocks casual abuse), not strong per-user auth.
RELAY_SHARED_SECRET=your-relay-shared-secret-here

# Database URLs
DATABASE_URL=sqlite://sessions.db?mode=rwc
VAULT_DATABASE_URL=sqlite://vault.db?mode=rwc

# Solana RPC URL (primary). Prod uses Triton One (rpcpool) — the x-token is embedded in
# the URL path and is a SECRET, so keep this only here (untracked), never in tracked files
# or the web frontend. Example: https://<your-endpoint>.devnet.rpcpool.com/<x-token>
SOLANA_RPC_URL=https://api.devnet.solana.com
# Fallback RPC used when the primary is unhealthy (circuit breaker → read_with_failover).
SOLANA_RPC_FALLBACK_URL=https://api.devnet.solana.com

# MagicBlock Ephemeral Rollup RPC (raw ER endpoint, used for account reads).
ER_RPC_URL=https://devnet-eu.magicblock.app/
# MagicBlock Magic Router — the generic per-transaction router (routes each
# tx to base or ER based on writable-account delegation state). Used for
# record_move / undelegate. Falls back to ER_RPC_URL if unset.
MAGIC_ROUTER_RPC_URL=https://devnet-router.magicblock.app

# Log format: "json" for structured one-object-per-line logs (production; each line
# carries the request_id correlation ID), anything else = human-readable (dev).
LOG_FORMAT=json

# "production" enables hard-fail config validation at startup (placeholder secrets
# refuse to boot). Leave unset for local dev.
APP_ENV=production

# Program ID (xfchess-game program on Solana) — canonical devnet deployment,
# matches declare_id! in programs/xfchess-game.
PROGRAM_ID=8tevgspityTTG45KvvRtWV4GZ2kuGDBYWMXouFGquyDU

# Transactional email (confirmation + waitlist) via Resend — https://resend.com
# Without RESEND_API_KEY, signups/waitlist are still recorded to data/*.jsonl but no email is sent.
RESEND_API_KEY=re_your-resend-api-key-here
# From address — must be on a domain you've verified in Resend for production.
# Defaults to Resend's shared test sender (onboarding@resend.dev) if unset.
MAIL_FROM=XFChess <hello@xfchess.com>

# Legacy: still used by dispute notification emails (backend/src/signing/routes/dispute.rs)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# TURN Server Configuration (for NAT traversal fallback)
# coturn runs co-located on the Hetzner VPS (178.104.55.19). Install/config is
# manual today — see deploy/README.md; there is no coturn deploy script in-tree.
TURN_SERVER=turns://178.104.55.19:5349?transport=tcp
TURN_USERNAME=xfchess_turn
TURN_PASSWORD=your-turn-password
TURN_REALM=178.104.55.19
TURN_SHARED_SECRET=your-turn-shared-secret

# Identity column crypto — REQUIRED (backend panics if unset).
# Generate each with:  openssl rand -hex 32   (64 hex chars)
IDENTITY_ENCRYPTION_KEY=your-64-hex-char-aes256-key
IDENTITY_SALT=your-64-hex-char-blind-index-salt

# Authorities (Base58 Private Keys) — use ONE DISTINCT key per role; never reuse
# the same keypair across roles (a single leak then compromises all of them).
# Make each with: solana-keygen new -o role.json, then base58-encode the 64 bytes.
FEE_PAYER_KEYS=your-feepayer-base58-key          # comma-separated for multiple
VPS_AUTHORITY_KEY=your-vps-authority-base58-key
KYC_AUTHORITY_KEY=your-kyc-authority-base58-key
# Treasury-withdrawal authority — signs withdraw_treasury (platform-fee payouts /
# manual refunds). MUST correspond to treasury_authority::ID in the program
# (keys/treasury_authority.json). Single dedicated wallet; rotate before mainnet.
# Base58 of the 64-byte keypair:  solana-keygen ... then base58-encode.
TREASURY_AUTHORITY_KEY=your-treasury-authority-base58-key
# Dispute authority — code reads DISPUTE_AUTHORITY_KEYPAIR (routes/dispute.rs).
# IMPORTANT: separate offline keypair before mainnet; do not reuse the VPS key.
DISPUTE_AUTHORITY_KEYPAIR=your-dispute-authority-base58-key

# Admin token — SECOND factor for financially-irreversible admin actions only
# (currently POST /admin/dispute/resolve; future treasury withdraw/refund).
# This is layered ON TOP of ADMIN_API_KEY: those routes require both the
# X-API-Key header AND this token in the request body (compared constant-time).
# Keep it DISTINCT from ADMIN_API_KEY. Generate with: openssl rand -hex 32
# Prod: store in a secrets manager, never commit to git.
ADMIN_TOKEN=your-very-secret-admin-token-here

# WebSocket endpoints for subscriptions
L1_WS_URL=wss://api.devnet.solana.com
ER_WS_URL=wss://devnet-eu.magicblock.app

# TEE Relayer configuration
MAGICBLOCK_TEE_URL=https://devnet-tee.magicblock.app
MAGICBLOCK_TEE_TOKEN=
