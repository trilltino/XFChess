# dev2 generated launcher scripts
.dev2-*.ps1
dev2-*.ps1

# Rust
target/
target-diag/
Cargo.lock
**/*.rs.bk
*.pdb

# Dependencies
node_modules/

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
.env.local

# Keys (sensitive)
keys/

# Large binaries
stockfish.exe

# IDE specific
.windsurf/

# Test data
tmp/
temp/
*.test

# Build artifacts
dist/
build/
release/

# Stale web build at repo root (frontend is built fresh by CI / deploy.ps1)
/index.html

# Bevy game assets (audio/fonts/models/pieces + icon/menu_click) are tracked via Git LFS
# — see .gitattributes. Only ignore stray build output that used to land here.
/assets/*.js
/assets/*.css

# Anchor
.anchor/

# Vite cache
web-solana/node_modules/.vite/

# Tauri
tauri/target/

# Rust build artifacts
*.so
*.dll
*.dylib

# SQLite database files (NEVER commit live databases)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Runtime / process state
*.pid
.backend.pid

# Editor scratch / temp files
*.tmp
*.tmp.*

# Secrets — belt-and-suspenders (also matched by .env rules above)
**/.env
**/.env.*
!**/.env.example
*.keypair
*-keypair.json
id.json

# Tauri generated
tauri/gen/

# Package lock files — kept for the npm projects CI actually builds
# (npm ci requires a committed lockfile; there is no root npm project).
**/package-lock.json
!web-solana/package-lock.json
!tauri/wallet-ui/package-lock.json
!tauri/tournament-admin/package-lock.json

# Generated JSON files — except the Anchor IDL, which the frontend imports
# directly and which a fresh checkout has no way to regenerate without a full
# Solana/Anchor toolchain (CI builds the web frontend without one).
web-solana/src/lib/*.json
!web-solana/src/lib/xfchess_game.json

# WASM package
xfchess-wasm/pkg/

# Temp markdown files
xfchess-anticheat-crate-*.md
