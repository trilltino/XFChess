fee-payer.json
kyc-authority.json
vps-authority.json
program-authority.json
new-program-id.json

# Wallets directory
/wallets/
*.key

# OS
Thumbs.db
desktop.ini

# Local SQLite databases (dev state, never commit)
/*.db

# Reference materials (too large for git)
/references/
/reference/

# Web build
/web/dist/
/web/pkg/
/web/target/
web-solana/dist/

# Personal settings (contains user preferences)
settings.json

# Temporary files
*.tmp
*.temp

# P2P identity keys (unique per peer instance)
xfchess_identity.key
xfchess_peer_*.key
launch_peer_*.bat

# Environment files — NEVER commit real secrets
**/.env
**/.env.local
**/.env.production
**/.env.staging
# Allow example/template files (no real values)
!**/.env.example

# Deploy secrets specifically
deploy/.env.production

# Sensitive wallet and key files
*.json
!web-react/package.json
!Cargo.toml
!Anchor.toml
!programs/xfchess-game/Cargo.toml
!backend/Cargo.toml
!crates/*/Cargo.toml
!wallet-popup/Cargo.toml
!web-react/tsconfig.json
!web-react/package.json
!web-react/vite.config.ts
!web-react/eslint.config.js
!wallet-popup/tauri.conf.json
