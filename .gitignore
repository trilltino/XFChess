!web-solana/package-lock.json
!web-solana/tsconfig.json
!web-solana/tsconfig.app.json
!web-solana/tsconfig.node.json

# Exclude all JSON files except specific ones
!idl.json
!idl_full.json
!web-solana/public/actions.json

