VITE_BACKEND_URL=
# Empty for relative URLs - nginx proxies /api to backend at localhost:8090

# Helius API Key (used by WagerPriceWidget for SOL/USD price feed)
# Get one free at https://dev.helius.xyz — widget falls back to CoinGecko if unset
VITE_HELIUS_API_KEY=

# MoonPay API Key (for SOL onboarding)
VITE_MOONPAY_API_KEY=
# MoonPay Publishable Key (widget)
VITE_MOONPAY_PUBLISHABLE_KEY=

# Transak API Key (for SOL onboarding)
VITE_TRANSAK_API_KEY=

# Banxa API Key (for SOL onboarding)
VITE_BANXA_API_KEY=
