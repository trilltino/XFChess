# Local dev secrets for the justfile (loaded via `set dotenv-load := true`).
# Copy to .env and fill in real values. .env is gitignored — NEVER commit it.
#
# Generate the hex secrets with: openssl rand -hex 32

# Solana RPC. Use a keyed provider (Helius/Triton) locally, or the public devnet
# endpoint. The keyed URL is a secret because it embeds your API key.
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_API_KEY=

# Auth / identity-vault crypto (64 hex chars = 32 bytes each)
JWT_SECRET=
IDENTITY_ENCRYPTION_KEY=
IDENTITY_SALT=

# Base58 keypairs. On devnet these may be one consolidated key; on mainnet use
# separate keys. NEVER hardcode these in tracked files.
FEE_PAYER_KEYS=
VPS_AUTHORITY_KEY=
KYC_AUTHORITY_KEY=

# Admin API key for /admin/* endpoints
ADMIN_API_KEY=dev
