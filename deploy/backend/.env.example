# ── XFChess Backend Environment ──────────────────────────────────────────────
# Copy to /opt/xfchess/.env on the server and fill in real values.
# NEVER commit this file with real secrets.

# ── Server ────────────────────────────────────────────────────────────────────
SIGNING_PORT=8090

# ── Database (absolute paths — binary runs from /opt/xfchess) ─────────────────
# These are created automatically on first run
SESSION_DB_URL=sqlite:///opt/xfchess/data/sessions.db?mode=rwc
VAULT_DB_URL=sqlite:///opt/xfchess/data/vault.db?mode=rwc

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
IDENTITY_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# Generate with: openssl rand -hex 32
IDENTITY_SALT=REPLACE_WITH_64_CHAR_HEX

# Relay shared secret — application-layer auth for the session-key signing
# endpoints (/move/record, /session/*, /game/finalize). Generate with
# `openssl rand -hex 32` and set the SAME value in the game client's environment
# (sent as X-Relay-Secret). Unset = fails open (network boundary only).
RELAY_SHARED_SECRET=REPLACE_WITH_64_CHAR_HEX

# Optional JWT lifetime override in seconds (default 604800 = 7 days)
# JWT_TTL_SECS=604800

# Admin API key — required for /admin/* and admin-tournament endpoints.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=REPLACE_WITH_SECURE_RANDOM

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ER_RPC_URL=https://mainnet.magicblock.app/
PROGRAM_ID=YOUR_DEPLOYED_PROGRAM_ID

# ── Keys (base58) ─────────────────────────────────────────────────────────────
# Devnet: All authorities consolidated to single key for convenience
# Mainnet: Should use separate keys for security (treasury offline, disputes separate, etc.)
FEE_PAYER_KEYS=BASE58_PRIVATE_KEY_1,BASE58_PRIVATE_KEY_2
VPS_AUTHORITY_KEY=BASE58_CONSOLIDATED_AUTHORITY_PRIVATE_KEY
KYC_AUTHORITY_KEY=BASE58_CONSOLIDATED_AUTHORITY_PRIVATE_KEY
HOST_TREASURY_PUBKEY=uLgR6Nx4KqQobj6e2mQUPeWQpMUauDRc2oz6wZg3Y6C

# ── USDC ──────────────────────────────────────────────────────────────────────
# Mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.REPLACE_WITH_REAL_KEY

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN
